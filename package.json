{
  "name": "k6-petstore",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test:pets:smoke": "k6 run performance/scenarios/pets/smoke.js",
    "test:pets:load": "k6 run performance/scenarios/pets/load.js",
    "test:pets:stress": "k6 run performance/scenarios/pets/stress.js",
    "test:pets:spike": "k6 run performance/scenarios/pets/spike.js",
    "test:pets:soak": "k6 run performance/scenarios/pets/soak.js",
    "test:pets:constant-rate": "k6 run performance/scenarios/pets/constant-rate.js",
    "test:pets:ramping-rate": "k6 run performance/scenarios/pets/ramping-rate.js",
    "test:users:smoke": "k6 run performance/scenarios/users/smoke.js",
    "test:users:load": "k6 run performance/scenarios/users/load.js",
    "test:users:stress": "k6 run performance/scenarios/users/stress.js",
    "test:users:all": "npm run test:users:load && npm run test:users:stress",
    "test:store:smoke": "k6 run performance/scenarios/store/smoke.js",
    "test:store:load": "k6 run performance/scenarios/store/load.js",
    "test:store:stress": "k6 run performance/scenarios/store/stress.js",
    "test:store:all": "npm run test:store:load && npm run test:store:stress",
    "test:pets:load:prod": "k6 run -e PROFILE=prod performance/scenarios/pets/load.js",
    "test:pets:stress:prod": "k6 run -e PROFILE=prod performance/scenarios/pets/stress.js",
    "test:pets:soak:prod": "k6 run -e PROFILE=prod performance/scenarios/pets/soak.js",
    "test:users:load:prod": "k6 run -e PROFILE=prod performance/scenarios/users/load.js",
    "test:users:stress:prod": "k6 run -e PROFILE=prod performance/scenarios/users/stress.js",
    "test:store:load:prod": "k6 run -e PROFILE=prod performance/scenarios/store/load.js",
    "test:store:stress:prod": "k6 run -e PROFILE=prod performance/scenarios/store/stress.js",
    "test:browser:smoke": "k6 run performance/scenarios/browser/smoke.js",
    "test:functional": "cd functional && npx playwright test",
    "test:functional:ui": "cd functional && npx playwright test --ui"
  },
  "keywords": [],
  "author": "Andrei",
  "license": "ISC",
  "description": "k6 performance and Playwright functional tests for the PetStore API"
}
